[5.219784, "o", "\u001b[34m\u25cf\u001b[0m  gpu: AMD card0 \u00b7 124.5 GiB (unified, inferred)\r\n\u001b[38;5;8m\u2502\u001b[0m  cpu: AMD RYZEN AI MAX+ 395 w/ Radeon 8060S \u00b7 16 cores \u00b7 AVX2 AVX-512 FMA\r\n\u001b[38;5;8m\u2502\u001b[0m  sys: 124.9 GiB MEM* \u00b7 244.6 GiB disk free \u00b7 linux/x86_64\r\n\u001b[38;5;8m\u2502\u001b[0m  \r\n\u001b[?25l\u001b[36m\u25c6\u001b[0m  Install method\r\n\u001b[36m\u2502\u001b[0m  \u001b[32m\u25cf\u001b[0m GitHub Releases \u001b[2m(verified asset for this host)\u001b[0m\r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mHomebrew\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mUse existing binary at /home/deepu/.local/state/llamadash/llama-cpp/b9245/llama-b9245/llama-server\u001b[0m \r\n\u001b[36m\u2502\u001b[0m  \u001b[2m\u25cb\u001b[0m \u001b[2mCustom path\u2026\u001b[0m \r\n\u001b[36m\u2514  \u001b[0m\r\n"]
